# SHADOW-TOOLZ notification settings
# Copy to .env and fill in real values.

# Slack alerts
SHADOW_SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Telegram alerts
SHADOW_TELEGRAM_BOT_TOKEN=<telegram-bot-token>
SHADOW_TELEGRAM_CHAT_ID=<telegram-chat-id>

# Email alerts
SHADOW_EMAIL_USER=alerts@your-company.com
SHADOW_EMAIL_PASS=<smtp-app-password>
SHADOW_ADMIN_EMAIL=soc@your-company.com
SHADOW_SMTP_HOST=smtp.gmail.com
SHADOW_SMTP_PORT=465
SHADOW_SMTP_TIMEOUT=10

# Alert storm protection (seconds)
SHADOW_NOTIFY_COOLDOWN_SECONDS=300

# Daily operations
SHADOW_DAILY_REPORT_TIME=00:00
SHADOW_PORT_SCAN_INTERVAL_SECONDS=86400
SHADOW_PORT_SCAN_TIMEOUT=0.35
SHADOW_PORT_SCAN_WORKERS=64

# IAM 2.0
# Auth mode: legacy | oidc | hybrid
SHADOW_AUTH_MODE=hybrid
# Legacy fallback token (used in legacy or hybrid mode)
SHADOW_API_TOKEN=change-this-token

# OIDC / Keycloak
OIDC_ISSUER=
OIDC_JWKS_URL=
OIDC_AUDIENCE=shadow-toolz
OIDC_CLIENT_ID=shadow-toolz-dashboard
OIDC_REDIRECT_URI=http://127.0.0.1:8055/
OIDC_SCOPES=openid profile email
