{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "eastus"
        },
        "namePrefix": {
            "value": "scc"
        },
        "hubAddressPrefix": {
            "value": "10.0.0.0/16"
        },
        "spokeAddressPrefixes": {
            "value": [
                "10.1.0.0/16",
                "10.2.0.0/16"
            ]
        },
        "onPremAddressPrefixes": {
            "value": [
                "172.16.0.0/16"
            ]
        },
        "enableFirewall": {
            "value": true
        }
    }
}