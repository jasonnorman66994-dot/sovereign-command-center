#!/usr/bin/env python3
"""
Web Vulnerability Scanner
=========================
Tests web applications for common vulnerabilities:
- SQL Injection (error-based, blind)
- Cross-Site Scripting (reflected XSS)
- Directory Traversal / Path Traversal
- Security Header Analysis
- Information Disclosure

For authorized use only - only scan applications you own or have permission to test.
"""

import re
import sys
import time
import urllib.parse
from dataclasses import dataclass, field
from html.parser import HTMLParser

try:
    import requests
    from requests.exceptions import RequestException
except ImportError:
    print("  [!] Install requests: pip install requests")
    sys.exit(1)


@dataclass
class Vulnerability:
    vuln_type: str
    severity: str  # "CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"
    url: str
    parameter: str = ""
    payload: str = ""
    evidence: str = ""
    description: str = ""


@dataclass
class ScanReport:
    target: str
    vulnerabilities: list = field(default_factory=list)
    forms_found: int = 0
    links_crawled: int = 0
    start_time: float = 0.0
    end_time: float = 0.0


# ─── SQL Injection Payloads ───────────────────────────────────────────
SQLI_PAYLOADS = [
    "' OR '1'='1",
    "' OR '1'='1' --",
    "1' ORDER BY 100--",
    "' UNION SELECT NULL--",
    "' AND 1=1--",
    "admin'--",
]

SQLI_ERRORS = [
    "sql syntax", "mysql_fetch", "syntax error", "unclosed quotation",
    "microsoft ole db", "odbc sql server driver", "postgresql",
    "ora-01756", "sqlite3", "warning: mysql", "valid mysql result",
    "pg_query", "you have an error in your sql",
    "supplied argument is not a valid", "mysql_num_rows",
    "division by zero", "microsoft sql native client error",
]

# ─── XSS Payloads ────────────────────────────────────────────────────
XSS_PAYLOADS = [
    '<script>alert("XSS")</script>',
    '<img src=x onerror=alert("XSS")>',
    '"><script>alert("XSS")</script>',
    '<svg/onload=alert("XSS")>',
    '"><img src=x onerror=alert(1)>',
]

# ─── Directory Traversal Payloads ─────────────────────────────────────
TRAVERSAL_PAYLOADS = [
    "../../../etc/passwd",
    "..\\..\\..\\windows\\system32\\drivers\\etc\\hosts",
    "....//....//....//etc/passwd",
    "..%252f..%252f..%252fetc/passwd",
]

TRAVERSAL_SIGNATURES = [
    "root:x:0:0", "root:*:0:0",  # /etc/passwd
    "[extensions]",  # win.ini
    "# localhost", "127.0.0.1",  # hosts file
]

# ─── Security Headers ────────────────────────────────────────────────
SECURITY_HEADERS = {
    "Strict-Transport-Security": {
        "severity": "HIGH",
        "description": "Missing HSTS header. Site vulnerable to protocol downgrade attacks.",
    },
    "Content-Security-Policy": {
        "severity": "MEDIUM",
        "description": "Missing CSP header. Site may be vulnerable to XSS and data injection.",
    },
    "X-Frame-Options": {
        "severity": "MEDIUM",
        "description": "Missing X-Frame-Options. Site may be vulnerable to clickjacking.",
    },
    "X-Content-Type-Options": {
        "severity": "LOW",
        "description": "Missing X-Content-Type-Options. Browser may MIME-sniff responses.",
    },
    "X-XSS-Protection": {
        "severity": "LOW",
        "description": "Missing X-XSS-Protection header (legacy but still useful).",
    },
    "Referrer-Policy": {
        "severity": "LOW",
        "description": "Missing Referrer-Policy. May leak sensitive URL info via referrer.",
    },
    "Permissions-Policy": {
        "severity": "LOW",
        "description": "Missing Permissions-Policy. Browser features not explicitly restricted.",
    },
}


class LinkExtractor(HTMLParser):
    """Extract links and forms from HTML."""

    def __init__(self, base_url: str):
        super().__init__()
        self.base_url = base_url
        self.links = set()
        self.forms = []
        self._current_form = None
        self._current_inputs = []

    def handle_starttag(self, tag, attrs):
        attrs_dict = dict(attrs)
        if tag == "a" and "href" in attrs_dict:
            href = attrs_dict["href"]
            full_url = urllib.parse.urljoin(self.base_url, href)
            if full_url.startswith(("http://", "https://")):
                self.links.add(full_url)

        elif tag == "form":
            self._current_form = {
                "action": urllib.parse.urljoin(self.base_url, attrs_dict.get("action", "")),
                "method": attrs_dict.get("method", "GET").upper(),
                "inputs": [],
            }

        elif tag == "input" and self._current_form is not None:
            self._current_form["inputs"].append({
                "name": attrs_dict.get("name", ""),
                "type": attrs_dict.get("type", "text"),
                "value": attrs_dict.get("value", ""),
            })

    def handle_endtag(self, tag):
        if tag == "form" and self._current_form:
            self.forms.append(self._current_form)
            self._current_form = None


def crawl(url: str, max_depth: int = 2) -> tuple[set, list]:
    """Crawl a website to discover URLs and forms."""
    visited = set()
    to_visit = [(url, 0)]
    all_forms = []
    domain = urllib.parse.urlparse(url).netloc

    session = requests.Session()
    session.headers.update({
        "User-Agent": "ShadowToolkit/1.0 (Security Scanner)"
    })
    session.verify = False

    while to_visit:
        current_url, depth = to_visit.pop(0)
        if current_url in visited or depth > max_depth:
            continue

        # Stay within the same domain
        if urllib.parse.urlparse(current_url).netloc != domain:
            continue

        visited.add(current_url)
        try:
            resp = session.get(current_url, timeout=5, allow_redirects=True)
            if "text/html" not in resp.headers.get("Content-Type", ""):
                continue

            extractor = LinkExtractor(current_url)
            extractor.feed(resp.text)

            all_forms.extend(extractor.forms)
            for link in extractor.links:
                if link not in visited:
                    to_visit.append((link, depth + 1))

        except RequestException:
            continue

    return visited, all_forms


def test_sqli(url: str, forms: list, session: requests.Session) -> list[Vulnerability]:
    """Test for SQL injection vulnerabilities."""
    vulns = []

    # Test URL parameters
    parsed = urllib.parse.urlparse(url)
    params = urllib.parse.parse_qs(parsed.query)
    for param_name, values in params.items():
        for payload in SQLI_PAYLOADS:
            test_params = {k: v[0] for k, v in params.items()}
            test_params[param_name] = payload
            test_url = f"{parsed.scheme}://{parsed.netloc}{parsed.path}?{urllib.parse.urlencode(test_params)}"
            try:
                resp = session.get(test_url, timeout=5)
                body_lower = resp.text.lower()
                for error in SQLI_ERRORS:
                    if error in body_lower:
                        vulns.append(Vulnerability(
                            vuln_type="SQL Injection",
                            severity="CRITICAL",
                            url=url,
                            parameter=param_name,
                            payload=payload,
                            evidence=error,
                            description=f"Error-based SQLi detected via parameter '{param_name}'",
                        ))
                        break
            except RequestException:
                continue

    # Test forms
    for form in forms:
        for inp in form["inputs"]:
            if not inp["name"] or inp["type"] in ("submit", "hidden", "button"):
                continue
            for payload in SQLI_PAYLOADS[:3]:  # Fewer payloads for forms
                data = {i["name"]: i["value"] or "test" for i in form["inputs"] if i["name"]}
                data[inp["name"]] = payload
                try:
                    if form["method"] == "POST":
                        resp = session.post(form["action"], data=data, timeout=5)
                    else:
                        resp = session.get(form["action"], params=data, timeout=5)

                    body_lower = resp.text.lower()
                    for error in SQLI_ERRORS:
                        if error in body_lower:
                            vulns.append(Vulnerability(
                                vuln_type="SQL Injection",
                                severity="CRITICAL",
                                url=form["action"],
                                parameter=inp["name"],
                                payload=payload,
                                evidence=error,
                                description=f"Error-based SQLi in form field '{inp['name']}'",
                            ))
                            break
                except RequestException:
                    continue

    return vulns


def test_xss(url: str, forms: list, session: requests.Session) -> list[Vulnerability]:
    """Test for reflected XSS vulnerabilities."""
    vulns = []

    # Test URL parameters
    parsed = urllib.parse.urlparse(url)
    params = urllib.parse.parse_qs(parsed.query)
    for param_name, values in params.items():
        for payload in XSS_PAYLOADS:
            test_params = {k: v[0] for k, v in params.items()}
            test_params[param_name] = payload
            test_url = f"{parsed.scheme}://{parsed.netloc}{parsed.path}?{urllib.parse.urlencode(test_params)}"
            try:
                resp = session.get(test_url, timeout=5)
                if payload in resp.text:
                    vulns.append(Vulnerability(
                        vuln_type="Cross-Site Scripting (XSS)",
                        severity="HIGH",
                        url=url,
                        parameter=param_name,
                        payload=payload,
                        evidence="Payload reflected unescaped in response",
                        description=f"Reflected XSS via parameter '{param_name}'",
                    ))
                    break  # One proof is enough per parameter
            except RequestException:
                continue

    # Test forms
    for form in forms:
        for inp in form["inputs"]:
            if not inp["name"] or inp["type"] in ("submit", "hidden", "button"):
                continue
            for payload in XSS_PAYLOADS[:3]:
                data = {i["name"]: i["value"] or "test" for i in form["inputs"] if i["name"]}
                data[inp["name"]] = payload
                try:
                    if form["method"] == "POST":
                        resp = session.post(form["action"], data=data, timeout=5)
                    else:
                        resp = session.get(form["action"], params=data, timeout=5)

                    if payload in resp.text:
                        vulns.append(Vulnerability(
                            vuln_type="Cross-Site Scripting (XSS)",
                            severity="HIGH",
                            url=form["action"],
                            parameter=inp["name"],
                            payload=payload,
                            evidence="Payload reflected in form response",
                            description=f"Reflected XSS in form field '{inp['name']}'",
                        ))
                        break
                except RequestException:
                    continue

    return vulns


def test_traversal(url: str, session: requests.Session) -> list[Vulnerability]:
    """Test for directory traversal vulnerabilities."""
    vulns = []
    parsed = urllib.parse.urlparse(url)
    params = urllib.parse.parse_qs(parsed.query)

    for param_name in params:
        for payload in TRAVERSAL_PAYLOADS:
            test_params = {k: v[0] for k, v in params.items()}
            test_params[param_name] = payload
            test_url = f"{parsed.scheme}://{parsed.netloc}{parsed.path}?{urllib.parse.urlencode(test_params)}"
            try:
                resp = session.get(test_url, timeout=5)
                for sig in TRAVERSAL_SIGNATURES:
                    if sig in resp.text:
                        vulns.append(Vulnerability(
                            vuln_type="Directory Traversal",
                            severity="CRITICAL",
                            url=url,
                            parameter=param_name,
                            payload=payload,
                            evidence=sig,
                            description=f"Path traversal via '{param_name}' - system file exposed",
                        ))
                        break
            except RequestException:
                continue

    return vulns


def check_security_headers(url: str, session: requests.Session) -> list[Vulnerability]:
    """Check for missing security headers."""
    vulns = []
    try:
        resp = session.get(url, timeout=5)
        for header, info in SECURITY_HEADERS.items():
            if header.lower() not in {k.lower() for k in resp.headers}:
                vulns.append(Vulnerability(
                    vuln_type="Missing Security Header",
                    severity=info["severity"],
                    url=url,
                    parameter=header,
                    description=info["description"],
                ))

        # Check for info disclosure headers
        server = resp.headers.get("Server", "")
        if server and any(v in server.lower() for v in ["apache/", "nginx/", "iis/", "php/"]):
            vulns.append(Vulnerability(
                vuln_type="Information Disclosure",
                severity="LOW",
                url=url,
                parameter="Server",
                evidence=server,
                description=f"Server version exposed: {server}",
            ))

        powered_by = resp.headers.get("X-Powered-By", "")
        if powered_by:
            vulns.append(Vulnerability(
                vuln_type="Information Disclosure",
                severity="LOW",
                url=url,
                parameter="X-Powered-By",
                evidence=powered_by,
                description=f"Technology stack exposed: {powered_by}",
            ))

    except RequestException:
        pass

    return vulns


SEVERITY_COLORS = {
    "CRITICAL": "🔴",
    "HIGH": "🟠",
    "MEDIUM": "🟡",
    "LOW": "🔵",
    "INFO": "⚪",
}


def run_web_scanner(args):
    """Main web scanner entry point."""
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

    url = args.url
    if not url.startswith(("http://", "https://")):
        url = "http://" + url

    run_all = args.all
    run_sqli = args.sqli or run_all
    run_xss = args.xss or run_all
    run_traversal = args.traversal or run_all
    run_headers = args.headers or run_all

    if not any([run_sqli, run_xss, run_traversal, run_headers]):
        run_all = True
        run_sqli = run_xss = run_traversal = run_headers = True

    print(f"  [*] Target: {url}")
    print(f"  [*] Tests: ", end="")
    tests = []
    if run_sqli: tests.append("SQLi")
    if run_xss: tests.append("XSS")
    if run_traversal: tests.append("Traversal")
    if run_headers: tests.append("Headers")
    print(", ".join(tests))

    session = requests.Session()
    session.headers.update({"User-Agent": "ShadowToolkit/1.0 (Security Scanner)"})
    session.verify = False

    # Crawl
    print(f"\n  [*] Crawling (depth={args.depth})...")
    urls, forms = crawl(url, max_depth=args.depth)
    print(f"  [*] Found {len(urls)} URLs and {len(forms)} forms")

    report = ScanReport(target=url, forms_found=len(forms), links_crawled=len(urls), start_time=time.time())

    # Run tests
    for page_url in urls:
        if run_sqli:
            sys.stdout.write(f"\r  [*] Testing SQLi: {page_url[:70]}...")
            sys.stdout.flush()
            report.vulnerabilities.extend(test_sqli(page_url, forms, session))

        if run_xss:
            sys.stdout.write(f"\r  [*] Testing XSS: {page_url[:70]}...")
            sys.stdout.flush()
            report.vulnerabilities.extend(test_xss(page_url, forms, session))

        if run_traversal:
            sys.stdout.write(f"\r  [*] Testing Traversal: {page_url[:60]}...")
            sys.stdout.flush()
            report.vulnerabilities.extend(test_traversal(page_url, session))

    if run_headers:
        sys.stdout.write(f"\r  [*] Checking security headers...{' ' * 40}")
        sys.stdout.flush()
        report.vulnerabilities.extend(check_security_headers(url, session))

    report.end_time = time.time()
    print("\r" + " " * 80)
    print()

    # Deduplicate
    seen = set()
    unique_vulns = []
    for v in report.vulnerabilities:
        key = (v.vuln_type, v.url, v.parameter, v.payload)
        if key not in seen:
            seen.add(key)
            unique_vulns.append(v)
    report.vulnerabilities = unique_vulns

    # Results
    print("  ╔═══════════════════════════════════════════════════════════════════╗")
    print("  ║  WEB VULNERABILITY SCAN RESULTS                                 ║")
    print("  ╠═══════════════════════════════════════════════════════════════════╣")
    print(f"  ║  Target:   {url[:55]}")
    print(f"  ║  URLs:     {report.links_crawled} crawled | {report.forms_found} forms found")
    print(f"  ║  Duration: {report.end_time - report.start_time:.2f}s")
    print(f"  ║  Findings: {len(report.vulnerabilities)} vulnerabilities")
    print("  ╠═══════════════════════════════════════════════════════════════════╣")

    if not report.vulnerabilities:
        print("  ║  No vulnerabilities found! (or target has good defenses)        ║")
    else:
        # Sort by severity
        severity_order = {"CRITICAL": 0, "HIGH": 1, "MEDIUM": 2, "LOW": 3, "INFO": 4}
        report.vulnerabilities.sort(key=lambda v: severity_order.get(v.severity, 5))

        for i, v in enumerate(report.vulnerabilities, 1):
            icon = SEVERITY_COLORS.get(v.severity, "⚪")
            print(f"  ║")
            print(f"  ║  {icon} [{v.severity}] {v.vuln_type}")
            print(f"  ║     URL:       {v.url[:55]}")
            if v.parameter:
                print(f"  ║     Parameter: {v.parameter}")
            if v.payload:
                print(f"  ║     Payload:   {v.payload[:55]}")
            if v.evidence:
                print(f"  ║     Evidence:  {v.evidence[:55]}")
            print(f"  ║     Detail:    {v.description[:55]}")

    print("  ║")
    print("  ╚═══════════════════════════════════════════════════════════════════╝")

    # Summary counts
    counts = {}
    for v in report.vulnerabilities:
        counts[v.severity] = counts.get(v.severity, 0) + 1
    if counts:
        print()
        print("  Summary: ", end="")
        for sev in ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]:
            if sev in counts:
                print(f"{SEVERITY_COLORS[sev]} {sev}: {counts[sev]}  ", end="")
        print()
