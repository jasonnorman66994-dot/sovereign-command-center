{
  "dashboard": {
    "id": null,
    "title": "Email & Login Security Monitoring",
    "tags": ["security", "email", "login", "incident response"],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "5m",
    "panels": [
      {
        "type": "timeseries",
        "title": "Emails Sent Per Sender Per Hour",
        "datasource": "CSV or SQL",
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        },
        "targets": [
          {
            "refId": "A",
            "format": "table",
            "rawSql": "SELECT Hour, Sender, SUM(Count) as TotalEmails FROM mail_activity GROUP BY Hour, Sender ORDER BY Hour, TotalEmails DESC;"
          }
        ],
        "gridPos": {"h":8,"w":12,"x":0,"y":0}
      },
      {
        "type": "piechart",
        "title": "Top Email Senders",
        "datasource": "CSV or SQL",
        "targets": [
          {
            "refId": "B",
            "format": "table",
            "rawSql": "SELECT Sender, SUM(Count) as TotalEmails FROM mail_activity GROUP BY Sender ORDER BY TotalEmails DESC LIMIT 10;"
          }
        ],
        "gridPos": {"h":8,"w":12,"x":12,"y":0}
      },
      {
        "type": "barchart",
        "title": "Failed vs Successful Logins Per User/IP",
        "datasource": "CSV or SQL",
        "targets": [
          {
            "refId": "C",
            "format": "table",
            "rawSql": "SELECT User, IP, Status, COUNT(*) as Attempts FROM login_attempts GROUP BY User, IP, Status;"
          }
        ],
        "gridPos": {"h":8,"w":12,"x":0,"y":8}
      },
      {
        "type": "heatmap",
        "title": "Login Attempts by Hour",
        "datasource": "CSV or SQL",
        "targets": [
          {
            "refId": "D",
            "format": "table",
            "rawSql": "SELECT Hour, User, COUNT(*) as Attempts FROM login_attempts GROUP BY Hour, User;"
          }
        ],
        "gridPos": {"h":8,"w":12,"x":12,"y":8}
      }
    ]
  }
}
